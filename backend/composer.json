{
  "name": "stock-management/api",
  "description": "Stock Management REST API (Slim 4)",
  "type": "project",
  "require": {
    "php": "^8.1",
    "slim/slim": "^4.12",
    "slim/psr7": "^1.6",
    "firebase/php-jwt": "^6.11",
    "vlucas/phpdotenv": "^5.6"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "audit": {
      "block-insecure": false
    }
  },
  "scripts": {
    "migrate": "php scripts/migrate.php",
    "db:seed": "php scripts/seed.php"
  }
}
